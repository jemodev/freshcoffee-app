---
import AdminOrdersLayout from "@/layouts/AdminOrdersLayout.astro";
import { orderStatusOptions } from "@/components/admin/OrderStatusNav.astro";
const { status } = Astro.params;

const currentStatus = orderStatusOptions.find(
    (option) => option.value === status,
);
const displayStatus = currentStatus ? currentStatus.label : "desconocida";
---

<AdminOrdersLayout title={`Administrar ordenes - ${status}`}>
    <p>
        Aquí puedes ver y gestionar todas las órdenes {displayStatus}. Haz clic
        en cada orden para ver más detalles o actualizar su estado.
    </p>
</AdminOrdersLayout>
