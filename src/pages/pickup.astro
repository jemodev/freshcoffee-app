---
import Layout from "@/layouts/Layout.astro";
import Logo from "@/assets/logo.svg";
import { PickupDisplay } from "@/components/orders/PickupDisplay";

const title = "Últimas ordenes listas";
---

<Layout title={title}>
    <main class="bg-amber-400 min-h-screen py-20">
        <div
            class="mx-auto max-w-4xl shadow bg-white p-20 rounded-2xl flex flex-col items-center space-y-10"
        >
            <h1 class="text-center text-3xl font-black text-slate-900">
                {title}
            </h1>
            <Logo />

            <PickupDisplay client:only="react" />
        </div>
    </main>
</Layout>
