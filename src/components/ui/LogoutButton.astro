<button
    class="bg-red-500 hover:bg-red-600 text-lg text-white w-full mt-5 p-3 uppercase font-bold cursor-pointer rounded-xl"
    id="logout-button">Cerrar Sesión</button
>

<script>
    import { actions } from "astro:actions";
    import { navigate } from "astro:transitions/client";
    const logoutButton = document.getElementById("logout-button");
    if (logoutButton) {
        logoutButton.addEventListener("click", () => {
            actions.auth.signOut();
            navigate("/auth/login");
        });
    }
</script>
